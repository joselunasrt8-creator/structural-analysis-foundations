{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/joselunasrt8-creator/structural-analysis-foundations/schemas/research-object.schema.json",
  "title": "Structural Analysis Foundations Research Object",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "kind",
    "domain",
    "slug",
    "version",
    "title",
    "paper",
    "canonical_statement",
    "provenance",
    "dependencies",
    "validation",
    "exports",
    "lifecycle_status",
    "maturity"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*$"
    },
    "kind": {
      "type": "string",
      "enum": ["definition", "theorem", "concept", "claim", "interface"]
    },
    "domain": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "paper": {
      "type": "string",
      "pattern": "^paper-[0-9]+-[a-z][a-z0-9-]*$"
    },
    "canonical_statement": {
      "type": "string",
      "minLength": 1
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {
        "source": {
          "$ref": "#/$defs/source_reference"
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "relation"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*\\.[a-z][a-z0-9-]*$"
          },
          "relation": {
            "type": "string",
            "enum": ["depends_on", "refines", "supports", "uses"]
          }
        }
      },
      "uniqueItems": true
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["not_validated", "validated"]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "exports": {
      "type": "object",
      "additionalProperties": false,
      "properties": {}
    },
    "lifecycle_status": {
      "type": "string",
      "enum": ["draft", "reviewed", "published", "deprecated"]
    },
    "maturity": {
      "type": "string",
      "enum": ["seed", "extracted", "verified"]
    }
  },
  "$defs": {
    "source_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "anchor"],
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1
        },
        "anchor": {
          "type": "string",
          "minLength": 1
        },
        "lines": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    }
  }
}
