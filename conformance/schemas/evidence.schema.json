{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "branch": {"type": "string"},
    "canonical_outputs": {"type": "object"},
    "canonical_projection_timestamp": {"type": "string"},
    "commit_sha": {"type": "string"},
    "dependency_relations": {"type": "array"},
    "diagnostics": {"type": "array"},
    "execution_failure": {"type": "boolean"},
    "fixture_id": {"type": "string"},
    "generated_artifacts": {"type": "array"},
    "implementation_version": {"type": "string"},
    "observed_execution_timestamp": {"type": "string"},
    "proof_obligations": {"type": "object"},
    "provenance": {"type": "object"},
    "repository": {"type": "string"},
    "repository_url": {"type": "string"},
    "required_diagnostics": {"type": "array"},
    "research_object_id": {"type": "string"},
    "run_mode": {"enum": ["reference", "external"]},
    "schema_failure": {"type": "boolean"},
    "semantic_result": {"enum": ["PASS", "DRIFT", "FAIL", "UNKNOWN", "UNOBSERVED"]},
    "structural_invariants": {"type": "object"},
    "structural_metrics": {"type": "object"}
  },
  "required": [
    "repository",
    "repository_url",
    "commit_sha",
    "branch",
    "implementation_version",
    "research_object_id",
    "fixture_id",
    "observed_execution_timestamp",
    "canonical_projection_timestamp",
    "semantic_result",
    "diagnostics",
    "generated_artifacts",
    "structural_metrics",
    "provenance"
  ],
  "title": "Canonical Conformance Evidence",
  "type": "object"
}
